---
// The proof section — a fluid bento grid, not a locked table. Tiles size
// themselves to what they hold: small stat cards, larger media tiles, wide
// quote/highlight tiles. Columns use auto-fill and rows a fixed base unit
// with per-tile spans, so it packs tightly (no vertical voids) and reflows
// on its own for phone, tablet, and desktop — never a fixed, symmetrical
// grid. Media tiles are landscape boxes with overflow hidden; a real photo
// or video dropped in should use `width/height:100%; object-fit:cover`, so
// it fills the tile by cropping — it never stretches or distorts.
const { proj } = Astro.props;
const media = [proj.media, proj.media2].filter(Boolean);
---
<div class="bento">
  {proj.ledger.map((row, i) => (
    <div class:list={['tile', 'stat', i === 0 && 'stat--lead']}>
      <div class="stat-n">{row.n}</div>
      <div class="stat-l">{row.l}</div>
      {row.src && <div class="stat-src">per {row.src}</div>}
    </div>
  ))}

  {proj.live.href ? (
    <a class="tile action action--dark" href={proj.live.href} target="_blank" rel="noopener noreferrer">
      <span class="act-note">{proj.live.note}</span>
      <span class="act-main">{proj.live.label} →</span>
    </a>
  ) : (
    <div class="tile action action--dark is-soon">
      <span class="act-note">{proj.live.note} · coming soon</span>
      <span class="act-main">{proj.live.label} →</span>
    </div>
  )}

  {proj.pdfs.map((pdf) => (
    <a class="tile action action--light" href={pdf.href} target="_blank" rel="noopener noreferrer">
      <span class="act-note">{pdf.label}</span>
      <span class="act-main">Read the PDF →</span>
    </a>
  ))}

  {media.map((m) => {
    const isVideo = Boolean(m.src && m.video);
    const isPhoto = Boolean(m.src && !m.video);
    return (
      <div class="tile media">
        {isVideo && (
          <video class="m-fill" controls preload="metadata" playsinline aria-label={m.alt}>
            <source src={m.src} type="video/mp4" />
          </video>
        )}
        {isPhoto && <img class="m-fill" src={m.src} alt={m.alt} loading="lazy" decoding="async" />}
        {!m.src && m.video && <span class="m-play" aria-hidden="true">▶</span>}
        {m.corner && <span class="m-corner m-badge">{m.corner}</span>}
        {!isVideo && (
          <span class:list={['m-cap', isPhoto && 'm-badge']}>{m.label} · <em>{m.sub}</em></span>
        )}
      </div>
    );
  })}

  {proj.quote && (
    <div class="tile quote">
      <p class="q-text serif">{proj.quote.text}</p>
      <div class="q-attr"><span class="q-line"></span>{proj.quote.attr}</div>
    </div>
  )}

  {proj.note && (
    <div class="tile highlight">
      <div class="n-eyebrow">{proj.note.eyebrow}</div>
      <div class="n-big">{proj.note.big}</div>
      <p class="n-sub">{proj.note.sub}</p>
    </div>
  )}
</div>

<style>
  .bento {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 220px), 1fr));
    grid-auto-rows: 78px;          /* base unit; tiles span N rows */
    grid-auto-flow: row dense;
    gap: 14px;
  }
  .tile {
    border-radius: var(--r);
    border: 1px solid var(--line);
    background: var(--card);
    padding: 22px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* stat cards — the small tiles (2 units tall) */
  .stat { grid-row: span 2; justify-content: space-between; gap: 12px; }
  .stat--lead { grid-column: span 2; }
  .stat-n {
    font-size: clamp(30px, 3.4vw, 40px); font-weight: 800; letter-spacing: -0.02em;
    color: var(--accent); font-variant-numeric: tabular-nums; line-height: 1.02;
  }
  .stat--lead .stat-n { font-size: clamp(38px, 4.6vw, 54px); }
  .stat-l { font-size: 13.5px; color: var(--muted-2); line-height: 1.45; }
  .stat-src { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--faint); }

  /* action tiles — live link + case-study PDFs (2 units tall) */
  .action { grid-row: span 2; justify-content: space-between; gap: 16px; text-decoration: none; transition: background .2s ease, border-color .2s ease, color .2s ease; }
  .action--dark { background: var(--ink); color: var(--canvas); border-color: var(--ink); }
  .action--dark:hover { background: var(--accent); border-color: var(--accent); }
  .action--dark.is-soon { opacity: 0.92; }
  .action--dark.is-soon:hover { background: var(--ink); }
  .action--light { color: var(--ink); }
  .action--light:hover { border-color: var(--accent); color: var(--accent); }
  .act-note { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.06em; text-transform: uppercase; opacity: 0.72; }
  .act-main { font-size: 16px; font-weight: 700; }

  /* media — larger landscape tiles (spans 2 cols, 3 units tall). A real
     photo/video fills the tile via object-fit: cover — it crops to fit,
     it never stretches or distorts, no matter the source's own aspect ratio. */
  .media {
    grid-column: span 2; grid-row: span 3;
    position: relative; justify-content: flex-end; padding: 18px;
    background: repeating-linear-gradient(135deg, rgba(26,24,19,0.055) 0 13px, rgba(26,24,19,0.02) 13px 26px);
  }
  .m-fill { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; background: #000; }
  .m-cap { position: relative; font-family: var(--font-mono); font-size: 12px; color: var(--muted); }
  .m-cap em { color: var(--faint); font-style: normal; }
  .m-corner { position: absolute; top: 12px; right: 12px; font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.14em; color: var(--accent); }
  /* over a real photo, captions/corner tags get a dark chip so they stay
     legible regardless of what's underneath */
  .m-badge {
    z-index: 1; background: rgba(20, 18, 14, 0.72); color: #f2ede3;
    padding: 6px 10px; border-radius: 6px; backdrop-filter: blur(3px);
  }
  .m-badge em { color: rgba(242, 237, 227, 0.75); }
  .m-play {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 56px; height: 56px; border-radius: 50%; background: var(--accent);
    display: flex; align-items: center; justify-content: center; color: #fff; font-size: 17px; padding-left: 3px;
    box-shadow: 0 10px 26px rgba(74, 47, 29, 0.35);
  }

  /* quote + highlight — wide tiles (spans 2 cols, 3 units tall) */
  .quote { grid-column: span 2; grid-row: span 3; justify-content: center; gap: 16px; }
  .q-text { font-size: clamp(19px, 2vw, 25px); line-height: 1.32; color: var(--ink); }
  .q-attr { display: flex; align-items: center; gap: 12px; font-family: var(--font-mono); font-size: 11.5px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--muted); }
  .q-line { width: 22px; height: 1px; background: rgba(26, 24, 19, 0.3); }

  .highlight { grid-column: span 2; grid-row: span 3; gap: 10px; justify-content: center; }
  .n-eyebrow { font-family: var(--font-mono); font-size: 11.5px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); }
  .n-big { font-size: clamp(22px, 2.4vw, 30px); font-weight: 700; letter-spacing: -0.01em; color: var(--ink); }
  .n-sub { font-size: 14.5px; color: var(--muted); line-height: 1.55; }

  /* On a single-column grid the span-2 tiles just fill the one column; give
     the media a touch more height so a landscape photo still reads well. */
  @media (max-width: 480px) {
    .stat--lead, .media, .quote, .highlight { grid-column: 1 / -1; }
  }
</style>
