---
// Labeled placeholder tile — stands in for a real photo/video until the asset
// is dropped in. Pure CSS (no <img>), so there are no broken-image links.
// The file-label caption style is deliberate — it's the site's documentation
// vernacular; keep the same voice in real captions once assets land.
const { label, sub = 'real photo — drop in', video = false, ratio = '4 / 5', corner } = Astro.props;
---
<div class="ph" style={`aspect-ratio:${ratio}`}>
  {video && <div class="ph-play" aria-hidden="true">▶</div>}
  <div class="ph-cap">
    <div class="ph-label">{label}</div>
    <div class="ph-sub">{sub}</div>
  </div>
  {corner && <div class="ph-corner">{corner}</div>}
</div>

<style>
  .ph {
    position: relative; width: 100%; border-radius: var(--r-card); overflow: hidden;
    border: 1px solid var(--line);
    background: repeating-linear-gradient(135deg, rgba(26,24,19,0.055) 0 13px, rgba(26,24,19,0.02) 13px 26px);
    box-shadow: 0 22px 50px rgba(26, 24, 19, 0.09);
    display: flex; align-items: center; justify-content: center;
  }
  .ph-cap { position: relative; text-align: center; font-family: var(--font-mono); }
  .ph-label { font-size: 13px; color: var(--muted); letter-spacing: 0.04em; }
  .ph-sub { font-size: 11px; color: var(--faint); margin-top: 7px; letter-spacing: 0.04em; }
  .ph-play {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 58px; height: 58px; border-radius: 50%; background: var(--accent);
    display: flex; align-items: center; justify-content: center; color: #fff; font-size: 18px; padding-left: 3px;
    box-shadow: 0 10px 26px rgba(74, 47, 29, 0.35); z-index: 2;
  }
  .ph-corner { position: absolute; top: 16px; left: 16px; font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.12em; color: var(--faint); }
</style>
