---
const { project } = Astro.props;
const toneColor = project.statusTone === 'accent' ? 'var(--accent)' : 'var(--green)';
const toneText = project.statusTone === 'accent' ? '#b8401f' : 'var(--green-text)';
---
<a class="row" href={`/work/${project.slug}`}>
  <span class="idx">{project.order}</span>
  <div class="mid">
    <h3 class="r-name">{project.name}</h3>
    <p class="r-line">{project.cardLine}</p>
  </div>
  <div class="right">
    <span class="tag hide-sm">{project.cardTag}</span>
    <span class="status hide-xs" style={`color:${toneText}`}>
      <span class="s-dot" style={`background:${toneColor}`}></span>{project.status}
    </span>
    <span class="arrow" aria-hidden="true">↗</span>
  </div>
</a>

<style>
  .row {
    display: flex; align-items: center; gap: 28px; padding: 30px 34px; border-radius: 24px;
    background: var(--card); border: 1px solid var(--line); text-decoration: none; color: inherit;
    transition: transform .22s ease, border-color .22s ease, box-shadow .22s ease;
  }
  .row:hover { transform: translateY(-3px); border-color: rgba(217, 64, 42, 0.4); box-shadow: 0 18px 40px rgba(26, 24, 19, 0.08); }
  .idx { font-family: var(--font-mono); font-size: 14px; color: var(--accent); flex: 0 0 auto; }
  .mid { flex: 1; min-width: 0; }
  .r-name { font-size: clamp(22px, 2.6vw, 30px); font-weight: 700; letter-spacing: -0.02em; margin-bottom: 6px; }
  .r-line { font-size: 14.5px; color: var(--muted); line-height: 1.45; }
  .right { display: flex; align-items: center; gap: 18px; flex: 0 0 auto; }
  .arrow { font-size: 22px; color: var(--ink); }
  @media (max-width: 680px) {
    .row { gap: 16px; padding: 22px 20px; }
    .hide-sm { display: none; }
    .right { gap: 12px; }
  }
  @media (max-width: 460px) {
    .hide-xs { display: none; }
  }
</style>
