---
// A compact proof card for the home work grid. Order: title, then the
// single most impressive sourced number, then a plain one-sentence
// summary anyone can understand — no dates, no jargon, nothing truncated.
const { project } = Astro.props;
const headline = project.ledger[0];
---
<a class="card" href={`/work/${project.slug}`}>
  <div class="card-top">
    <h3 class="card-name">{project.name}</h3>
    <span class="card-arrow" aria-hidden="true">→</span>
  </div>

  <div class="card-stat">
    <div class="stat-n">{headline.n}</div>
    <div class="stat-l">{headline.l}</div>
  </div>

  <div class="card-divider"></div>

  <p class="card-summary">{project.cardLine}</p>
</a>

<style>
  .card {
    display: flex; flex-direction: column; gap: 16px; padding: 26px;
    border-radius: var(--r); background: var(--card); border: 1px solid var(--line);
    text-decoration: none; color: inherit; height: 100%;
    transition: transform .22s ease, border-color .22s ease, box-shadow .22s ease;
  }
  .card:hover { transform: translateY(-4px); border-color: var(--accent); box-shadow: 0 20px 44px rgba(26, 24, 19, 0.1); }
  .card:hover .card-name { color: var(--accent); }
  .card:hover .card-arrow { transform: translate(3px, -3px); color: var(--accent); }

  /* Titles and stat labels wrap to 1 or 2 lines depending on content, which
     used to leave the divider below at a different height per card. Both
     reserve fixed 2-line space (in em units, so it scales with the clamp)
     regardless of actual line count, keeping every divider level. */
  .card-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; }
  .card-name {
    font-size: clamp(20px, 2.2vw, 24px); font-weight: 700; letter-spacing: -0.01em;
    line-height: 1.15; min-height: calc(1.15em * 2); transition: color .2s ease;
  }
  .card-arrow { font-size: 18px; color: var(--faint); flex: 0 0 auto; transition: transform .2s ease, color .2s ease; }

  .card-stat { display: flex; flex-direction: column; gap: 6px; }
  .stat-n {
    font-size: clamp(32px, 4.2vw, 42px); font-weight: 800; letter-spacing: -0.02em;
    color: var(--accent); font-variant-numeric: tabular-nums; line-height: 1.05;
  }
  .stat-l { font-size: 13px; color: var(--muted-2); line-height: 1.4; min-height: calc(1.4em * 2); }

  .card-divider { height: 1px; background: var(--line); }

  .card-summary { font-size: 14.5px; color: var(--muted-2); line-height: 1.55; }

  @media (max-width: 480px) {
    .card { padding: 22px; }
  }
</style>
