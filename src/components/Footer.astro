---
import { EMAIL, INSTAGRAM, LINKEDIN } from '../data/site.js';
---
<footer class="site-footer">
  <div class="wrap">
    <div class="f-top">
      <h2 class="cta-head">Building where AI meets a real institution? <span class="serif">I'd like to talk.</span></h2>
      <div class="f-links">
        <a class="f-pill f-pill--solid" href={`mailto:${EMAIL}`}>Email</a>
        {LINKEDIN
          ? <a class="f-pill" href={LINKEDIN} target="_blank" rel="noopener noreferrer">LinkedIn</a>
          : <span class="f-pill is-soon" title="LinkedIn — coming soon" aria-disabled="true">LinkedIn</span>}
        <a class="f-pill" href={INSTAGRAM} target="_blank" rel="noopener noreferrer">Instagram</a>
      </div>
    </div>
    <div class="f-bottom">
      <div class="who">
        <span class="dot"></span>
        <span class="who-name">F. Aamir Ali</span>
        <span class="who-meta">· Builder &amp; founder · Surrey, BC</span>
      </div>
      <span class="copy">© 2026 — built, not templated</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 80px; background: var(--dark); color: var(--dark-text);
    border-radius: 40px 40px 0 0; padding: 64px 34px 34px;
  }
  .f-top {
    display: flex; align-items: flex-end; justify-content: space-between; gap: 40px; flex-wrap: wrap;
    padding-bottom: 46px; border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }
  .cta-head { font-size: clamp(28px, 4vw, 46px); font-weight: 700; letter-spacing: -0.03em; line-height: 1.05; max-width: 18ch; }
  .cta-head .serif { color: #f1ede5; }
  .f-links { display: flex; gap: 11px; flex-wrap: wrap; }
  .f-pill {
    font-family: var(--font-mono); font-size: 12.5px; letter-spacing: 0.05em; text-transform: uppercase;
    color: var(--dark-text); text-decoration: none; padding: 13px 22px; border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.22); transition: background .2s ease;
  }
  .f-pill:hover { background: rgba(255, 255, 255, 0.08); }
  .f-pill--solid { color: var(--dark); background: var(--dark-text); border-color: transparent; }
  .f-pill--solid:hover { background: #fff; }
  .f-pill.is-soon { opacity: 0.45; cursor: default; }
  .f-bottom { display: flex; align-items: center; justify-content: space-between; gap: 18px; flex-wrap: wrap; padding-top: 26px; }
  .who { display: flex; align-items: center; gap: 11px; }
  .who-name { font-weight: 700; font-size: 14px; }
  .who-meta { font-family: var(--font-mono); font-size: 12px; color: var(--dark-muted); }
  .copy { font-family: var(--font-mono); font-size: 12px; color: var(--dark-muted); }

  @media (max-width: 760px) {
    .site-footer { padding: 48px 20px 28px; border-radius: 32px 32px 0 0; }
  }
</style>
