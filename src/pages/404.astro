---
import Base from '../layouts/Base.astro';

const title = '404 — F. Aamir Ali';
const description = 'Page not found — but the work is right here.';
---
<Base title={title} description={description} canonical="/404">
  <section class="section nf">
    <div class="wrap">
      <div class="nf-code meta-line">Error 404</div>
      <h1 class="nf-title">No record <span class="serif">on file.</span></h1>
      <p class="nf-line">This page doesn't exist — but the work does. The records that do exist:</p>
      <nav class="nf-links" aria-label="Site pages">
        <a class="nf-link" href="/">Home <span aria-hidden="true">→</span></a>
        <a class="nf-link" href="/work/fleetbot">FleetBot <span aria-hidden="true">→</span></a>
        <a class="nf-link" href="/work/surrey-ai-summit">Surrey Youth AI Summit <span aria-hidden="true">→</span></a>
        <a class="nf-link" href="/work/ai-club">AI &amp; Innovation Club <span aria-hidden="true">→</span></a>
        <a class="nf-link" href="/about">About <span aria-hidden="true">→</span></a>
        <a class="nf-link" href="/honours">Honours <span aria-hidden="true">→</span></a>
      </nav>
    </div>
  </section>
</Base>

<style>
  .nf { padding-top: 148px; padding-bottom: 60px; min-height: 55vh; }
  .nf-code { color: var(--accent); margin-bottom: 16px; }
  .nf-title { font-size: clamp(40px, 6vw, 76px); font-weight: 800; letter-spacing: -0.02em; line-height: 0.98; margin-bottom: 18px; }
  .nf-line { font-size: 17px; color: var(--muted-2); margin-bottom: 34px; max-width: 44ch; }
  .nf-links { display: flex; flex-direction: column; max-width: 560px; border-top: 1px solid var(--line-2); }
  .nf-link {
    display: flex; justify-content: space-between; align-items: center; gap: 16px;
    padding: 16px 6px; border-bottom: 1px solid var(--line);
    font-weight: 600; font-size: 16px; color: var(--ink); text-decoration: none;
    transition: color .2s ease, padding-left .2s ease;
  }
  .nf-link:hover { color: var(--accent); padding-left: 12px; }
</style>
