---
import Base from '../../layouts/Base.astro';
import ProofGrid from '../../components/ProofGrid.astro';
import { projects } from '../../data/projects.js';
import { PERSON_ID, SITE_URL } from '../../data/site.js';

export function getStaticPaths() {
  return projects.map((p) => ({
    params: { slug: p.slug },
    props: { proj: p, others: projects.filter((x) => x.slug !== p.slug) },
  }));
}

const { proj, others } = Astro.props;

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: proj.name,
  description: proj.seoDescription,
  image: `${SITE_URL}${proj.ogImage}`,
  author: { '@id': PERSON_ID },
  publisher: { '@id': PERSON_ID },
  mainEntityOfPage: `${SITE_URL}/work/${proj.slug}`,
};
---
<Base
  title={proj.seoTitle}
  description={proj.seoDescription}
  canonical={`/work/${proj.slug}`}
  ogImage={proj.ogImage}
  ogType="article"
  jsonLd={articleJsonLd}
>
  <article class="section">
    <div class="wrap">
      <a class="back" href="/#work"><span aria-hidden="true">←</span> Back home</a>

      <!-- File line — factual status metadata, not a status pill -->
      <div class="file-line meta-line">{proj.fileLine}</div>

      <h1 class="p-name">{proj.name}</h1>
      <p class="p-tagline serif">{proj.tagline}</p>

      {proj.acts ? (
        <div class="p-acts">
          {proj.acts.map((act) => (
            <section class="act">
              <div class="act-kicker meta-line">{act.kicker}</div>
              <h2 class="act-title">{act.title}</h2>
              {act.paras.map((para) => <p class="p-para">{para}</p>)}
            </section>
          ))}
        </div>
      ) : (
        <div class="p-summary">
          {proj.intro.map((para) => <p class="p-para">{para}</p>)}
        </div>
      )}

      <div class="eyebrow proof-label">The proof</div>
      <ProofGrid proj={proj} />

      <div class="more">
        <div class="eyebrow" style="margin-bottom:16px;">More work</div>
        <div class="more-links">
          {others.map((o) => <a class="more-pill" href={`/work/${o.slug}`}>{o.name}</a>)}
        </div>
      </div>
    </div>
  </article>
</Base>

<style>
  .section { padding-top: 118px; }
  .back { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-mono); font-size: 12.5px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--muted); text-decoration: none; margin-bottom: 30px; transition: color .2s ease; }
  .back:hover { color: var(--accent); }

  .file-line { color: var(--accent); margin-bottom: 16px; }

  .p-name { font-size: clamp(38px, 6vw, 72px); font-weight: 800; letter-spacing: -0.02em; line-height: 0.98; margin-bottom: 16px; text-transform: uppercase; font-stretch: 85%; }
  .p-tagline { font-size: clamp(20px, 2.6vw, 30px); color: var(--muted-2); max-width: 44ch; line-height: 1.32; margin-bottom: 34px; }

  .p-acts { margin-bottom: 44px; }
  .act { max-width: 64ch; }
  .act + .act { margin-top: 34px; padding-top: 28px; border-top: 1px solid var(--line); }
  .act-kicker { color: var(--accent); margin-bottom: 10px; }
  .act-title { font-size: clamp(22px, 2.8vw, 30px); font-weight: 700; letter-spacing: -0.01em; margin-bottom: 14px; }

  .p-summary { max-width: 64ch; margin-bottom: 44px; }
  .p-para { font-size: 16.5px; line-height: 1.65; color: var(--muted-2); margin-bottom: 16px; }

  .proof-label { margin-bottom: 18px; }
  .more { margin-top: 44px; padding-top: 28px; border-top: 1px solid var(--line); }
  .more-links { display: flex; gap: 12px; flex-wrap: wrap; }
  .more-pill { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--ink); padding: 12px 20px; border-radius: var(--r-pill); border: 1px solid var(--line-2); background: var(--card); text-decoration: none; transition: border-color .2s ease, color .2s ease; }
  .more-pill:hover { border-color: var(--accent); color: var(--accent); }
  @media (max-width: 760px) {
    .section { padding-top: 94px; }
  }
</style>
