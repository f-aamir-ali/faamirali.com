---
import Base from '../../layouts/Base.astro';
import ProofGrid from '../../components/ProofGrid.astro';
import { projects } from '../../data/projects.js';
import { PERSON_ID, SITE_URL } from '../../data/site.js';

export function getStaticPaths() {
  return projects.map((p) => ({
    params: { slug: p.slug },
    props: { proj: p, others: projects.filter((x) => x.slug !== p.slug) },
  }));
}

const { proj, others } = Astro.props;
const toneColor = proj.statusTone === 'accent' ? 'var(--accent)' : 'var(--green)';

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: proj.name,
  description: proj.seoDescription,
  image: `${SITE_URL}${proj.ogImage}`,
  author: { '@id': PERSON_ID },
  publisher: { '@id': PERSON_ID },
  mainEntityOfPage: `${SITE_URL}/work/${proj.slug}`,
};
---
<Base
  title={proj.seoTitle}
  description={proj.seoDescription}
  canonical={`/work/${proj.slug}`}
  ogImage={proj.ogImage}
  ogType="article"
  jsonLd={articleJsonLd}
>
  <article class="section">
    <div class="wrap">
      <a class="back" href="/#work"><span aria-hidden="true">←</span> Back home</a>

      <div class="status-row">
        <span class="status-pill"><span class="s-dot" style={`background:${toneColor}`}></span>{proj.status}</span>
      </div>

      <h1 class="p-name">{proj.name}</h1>
      <p class="p-tagline serif">{proj.tagline}</p>

      <div class="p-summary">
        {proj.summary.map((para) => <p>{para}</p>)}
      </div>

      <div class="eyebrow proof-label">The proof</div>
      <ProofGrid proj={proj} />

      <div class="more">
        <div class="eyebrow" style="margin-bottom:16px;">More work</div>
        <div class="more-links">
          {others.map((o) => <a class="more-pill" href={`/work/${o.slug}`}>{o.name}</a>)}
        </div>
      </div>
    </div>
  </article>
</Base>

<style>
  .back { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-mono); font-size: 12.5px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--muted); text-decoration: none; margin-bottom: 30px; transition: color .2s ease; }
  .back:hover { color: var(--ink); }
  .status-row { margin-bottom: 18px; }
  .status-pill { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-mono); font-size: 11.5px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink); padding: 8px 14px; border-radius: 999px; border: 1px solid var(--line-2); background: var(--card); }
  .status-pill .s-dot { width: 7px; height: 7px; border-radius: 50%; }
  .p-name { font-size: clamp(38px, 6vw, 72px); font-weight: 700; letter-spacing: -0.035em; line-height: 0.98; margin-bottom: 16px; }
  .p-tagline { font-size: clamp(20px, 2.6vw, 30px); color: #3a362f; max-width: 42ch; line-height: 1.3; margin-bottom: 32px; }
  .p-summary { max-width: 62ch; margin-bottom: 44px; }
  .p-summary p { font-size: 16.5px; line-height: 1.65; color: #3a362f; margin-bottom: 16px; }
  .proof-label { margin-bottom: 18px; }
  .more { margin-top: 44px; padding-top: 28px; border-top: 1px solid var(--line); }
  .more-links { display: flex; gap: 12px; flex-wrap: wrap; }
  .more-pill { font-family: var(--font-mono); font-size: 12.5px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--ink); padding: 12px 20px; border-radius: 999px; border: 1px solid var(--line-2); background: var(--card); text-decoration: none; transition: border-color .2s ease; }
  .more-pill:hover { border-color: var(--ink); }
</style>
