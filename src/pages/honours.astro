---
// Honours & recognition — the formal record. Starts with the principal's
// recommendation letter, typed out word for word (including the signature
// block) so it's real, indexable, crawlable text — not a locked-away PDF
// scan. A "View original" button links to the actual signed PDF alongside
// it. Certificates and scholarship wins get added here as they're awarded.
import Base from '../layouts/Base.astro';
import { SITE_URL, profilePageJsonLd } from '../data/site.js';

const title = 'Honours | F. Aamir Ali';
const description =
  "The formal record of my recommendation letters, certificates, and scholarship wins, updated here as they happen.";
---
<Base
  title={title}
  description={description}
  canonical="/honours"
  ogImage="/og/honours.png"
  jsonLd={profilePageJsonLd(`${SITE_URL}/honours`)}
>
  <section class="section h-head">
    <div class="wrap">
      <a class="back" href="/"><span aria-hidden="true">←</span> Back home</a>
      <h1 class="h-title">Honours <span class="serif">&amp; recognition.</span></h1>
      <p class="h-sub">The formal record of my recommendation letters, certificates, and scholarship wins, updated here as they happen.</p>
    </div>
  </section>

  <section class="section letter-section">
    <div class="wrap">
      <div class="letter-inner">
      <div class="letter-head">
        <div class="eyebrow">Recommendation letter</div>
        <div class="letter-meta meta-line">Fleetwood Park Secondary School · June 15, 2026</div>
      </div>

      <article class="letter-card">
        <p class="l-salutation">To Whom It May Concern,</p>

        <p>It is my pleasure to write this reference letter for Fateh Aamir Ali, a Grade 11 student at Fleetwood Park Secondary School, who has distinguished himself as an innovative, driven, and forward-thinking leader. As Principal, I have observed his contributions closely, and I can confidently say his initiative and technical sophistication are exceptional at the secondary level.</p>

        <p>Aamir is the Founder and President of our AI &amp; Innovation Club, which he established in September 2025. Under his leadership, the club has grown to 20 active members and promotes hands-on engagement with emerging technologies. He fosters a culture of building by guiding peers through tools such as Lovable, N8N, and Make.com. He has also mobilized over 20 students to participate in national competitions, including the Best Buy AI Video Challenge, encouraging creativity and collaboration.</p>

        <p>Aamir's most impressive achievement is FLEETBOT, a fully functional AI assistant he independently developed for our school. This system uses advanced multi-agent architecture to support staff with real-time information retrieval. He converted extensive school documentation — including a 115-page handbook — into optimized formats, improving system accuracy, response times, and cost efficiency. He also successfully navigated district IT security requirements with professionalism and persistence. His work culminated in the deployment of a dedicated AI terminal in our main office on April 22, 2026 — the first student-built system of its kind at Fleetwood Park. The system was quickly adopted, processing over 150 queries in its first 10 days and demonstrating clear practical value.</p>

        <p>Beyond school, Aamir is the co-founder and lead organizer of the Surrey Youth AI Summit, a district-wide initiative connecting students across Greater Vancouver. He has coordinated multi-school participation, secured sponsorship, recruited a keynote speaker, and developed both the event's technical and promotional infrastructure.</p>

        <p>I offer my highest recommendation for Aamir in both academic and employment domains.</p>

        <p>Please do not hesitate to contact me if further information is required.</p>

        <div class="l-sign">
          <p class="l-close">Sincerely,</p>
          <p class="sig-name serif">Jodie Perry</p>
          <p class="sig-title meta-line">Principal, Fleetwood Park Secondary School</p>
        </div>
      </article>

      <a class="btn btn-dark view-original" href="/pdf/recommendation-letter.pdf" target="_blank" rel="noopener noreferrer">
        View the original letter (PDF) <span aria-hidden="true">→</span>
      </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .h-head { padding-top: 118px; padding-bottom: 10px; }
  .back { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-mono); font-size: 12.5px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--muted); text-decoration: none; margin-bottom: 30px; transition: color .2s ease; }
  .back:hover { color: var(--accent); }
  .h-title { font-size: clamp(40px, 5.4vw, 68px); font-weight: 700; letter-spacing: -0.02em; line-height: 0.98; margin-bottom: 18px; }
  .h-sub { font-size: 17px; color: var(--muted-2); max-width: 56ch; line-height: 1.55; }

  .letter-section { padding-top: 30px; padding-bottom: 80px; }
  .letter-inner { max-width: 900px; margin: 0 auto; }
  .letter-head { display: flex; align-items: baseline; justify-content: space-between; gap: 16px; flex-wrap: wrap; margin-bottom: 20px; }
  .letter-meta { color: var(--muted); }

  .letter-card {
    border-top: 2px solid var(--ink); border-bottom: 1px solid var(--line);
    background: var(--card); border-left: 1px solid var(--line); border-right: 1px solid var(--line);
    border-radius: var(--r); padding: 48px 56px;
  }
  .letter-card p { font-size: 16px; line-height: 1.72; color: var(--muted-2); margin-bottom: 18px; }
  .l-salutation { color: var(--ink); }
  .l-sign { margin-top: 30px; padding-top: 22px; border-top: 1px dashed var(--line-2); }
  .l-close { margin-bottom: 26px; }
  .sig-name { font-size: 26px; color: var(--ink); margin-bottom: 4px; }
  .sig-title { color: var(--muted); }

  .view-original { margin-top: 24px; }

  @media (max-width: 760px) {
    .h-head { padding-top: 94px; }
    .letter-card { padding: 32px 26px; }
  }
</style>
